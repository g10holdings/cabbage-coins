<script>
(function() {
    var today = new Date();
    today.setHours(0,0,0,0);
    document.querySelectorAll('.show-card').forEach(function(card) {
        var endDate = new Date(card.dataset.end);
        var isPast = endDate < today;
        var badge = card.querySelector('.show-badge-status');
        var dateBadge = card.querySelector('.show-date-badge');
        if (isPast) {
            card.style.opacity = '0.6';
            card.style.background = '#f9f9f9';
            dateBadge.style.background = '#888';
            badge.textContent = 'Past';
            badge.style.cssText = 'font-family:Roboto; font-weight:700; font-size:12px; padding:4px 12px; border-radius:20px; text-transform:uppercase; letter-spacing:0.5px; background:#f0f0f0; color:#888; white-space:nowrap;';
        } else {
            badge.textContent = 'Upcoming';
            badge.style.cssText = 'font-family:Roboto; font-weight:700; font-size:12px; padding:4px 12px; border-radius:20px; text-transform:uppercase; letter-spacing:0.5px; background:#e8f0fb; color:#1d3961; white-space:nowrap;';
        }
    });
})();
</script>
