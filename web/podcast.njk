<div class="container site-section main-section">
    <h1 class="text-center" style="color: #2e5090;">The Cabbage Coins Podcast</h1>
    <p class="text-center" style="font-size: 22px; max-width: 700px; margin: 0 auto 40px;">Conversations about the rare coin market with expert collectors, dealers, and enthusiasts. New episodes every week on <a href="https://www.youtube.com/@cabbage_coins" target="_blank">YouTube</a>.</p>

<div class="podcast-episodes">
    {% for episode in podcast %}
    <div class="podcast-episode">
        <div class="ratio ratio-16x9">
            <iframe src="https://www.youtube.com/embed/{{ episode.videoId }}" 
                    title="{{ episode.title }}" 
                    allowfullscreen></iframe>
        </div>
        <h3>{{ episode.title }}</h3>
        <p class="podcast-meta">
            {% if episode.views %}{{ episode.views | int | string }} views · {% endif %}{{ episode.publishedAt }}
        </p>
    </div>
    {% endfor %}
</div>

    <div class="text-center" style="margin-top: 40px; padding-bottom: 40px;">
        <a href="https://www.youtube.com/@cabbage_coins/podcasts" target="_blank" class="btn btn-primary" style="font-size: 18px; padding: 12px 30px;">View All Episodes on YouTube</a>
    </div>
</div>