---
date: 2022-01-02
eleventyNavigation:
  key: inventory
  order: 1
layout: layouts/base.njk
tags:
  - nav
navtitle: Inventory
title: Cabbage Coins | Inventory
---
<div class="container site-section preview-grid" id="listing-grid-container">
<div id="inventory-controls">
    <!-- Row 1: Product count far left -->
    <div style="margin-bottom:8px; text-align:left;">
        <h2 id="product-count-all" class="active" style="font-size:24px; color:#6289c1; font-family:'Noto Serif Display'; font-weight:800; margin:0;">{{ collections.listingsNewest.length }} Products</h2>
        <h2 id="product-count-sold" style="font-size:24px; color:#6289c1; font-family:'Noto Serif Display'; font-weight:800; margin:0;">{{ collections.listingsNewest.length - collections.listingsNotsold.length }} Products</h2>
    </div>

    <!-- Row 2: Show Sold left, CAC Only right -->
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:14px;">
        <label style="display:inline-flex; align-items:center; gap:8px; font-family:'Noto Serif Display'; font-weight:800; font-size:15px; color:#6289c1; cursor:pointer;">
            <input type="checkbox" checked id="show-sold-check" name="showsold" style="width:16px; height:16px; cursor:pointer;">
            Show Sold
        </label>
        <label style="display:inline-flex; align-items:center; gap:8px; font-family:'Noto Serif Display'; font-weight:800; font-size:15px; color:#4a9e6b; cursor:pointer;">
            <input type="checkbox" id="cac-filter-check" style="width:16px; height:16px; cursor:pointer; accent-color:#4a9e6b;">
            <img src="/assets/img/caccoin.png" style="height:24px;">
            Only
        </label>
    </div>

    <!-- Row 3: Filter buttons left, sort dropdown far right -->
    <div class="inventory-filter-row">
        <div class="inventory-filter-buttons">
            <span class="filter-label">Filter</span>
            <button class="filter-btn active-filter" data-filter="all">All</button>
            <button class="filter-btn" data-filter="Gold">Gold</button>
            <button class="filter-btn" data-filter="Silver">Silver</button>
            <button class="filter-btn" data-filter="Copper/Bronze">Copper/Bronze</button>
            <button class="filter-btn" data-filter="Vintage Ingot">Vintage Ingot</button>
            <button class="filter-btn" data-filter="Foreign">Foreign</button>
        </div>
        <select name="sort" id="sort">
            <option value="catalogasc">PCGS Catalog #</option>
            <option value="newest">Newest Items</option>
            <option value="priceasc">Price (low to high)</option>
            <option value="pricedsc">Price (high to low)</option>
        </select>
    </div>
</div>
<div class="listings-container">
<div class="container site-section preview-grid listing fade-in" id="listings-catalog">
    <div class="row preview-grid listing-row">
        {% set listinggrid = collections.myListings%}
        {% include "listinggrid_catalog.njk" %} 
    </div>
</div>
<div class="container site-section preview-grid listing fade-in" id="listings-latest">
    <div class="row preview-grid listing-row">
        {% set listinggrid = collections.myListings%}
        {% include "listinggrid.njk" %} 

    </div>
</div>
<div class="container site-section preview-grid listing fade-in" id="listings-priceasc">
    <div class="row preview-grid listing-row">
        {% set listinggrid = collections.myListings%}
        {% include "listinggrid_priceasc.njk" %}

    </div>
</div>
<div class="container site-section preview-grid listing fade-in" id="listings-pricedsc">
    <div class="row preview-grid listing-row">
        {% set listinggrid = collections.myListings%}
        {% include "listinggrid_pricedsc.njk" %} 
    </div>
</div>
</div>
<script>
document.querySelectorAll('.image-dummy[data-img-back]').forEach(function(el) {
    const front = el.dataset.imgFront;
    const back = el.dataset.imgBack;
    if (!back || back === 'undefined?h=900') return;
    el.addEventListener('mouseenter', function() {
        el.style.backgroundImage = 'url(' + back + ')';
    });
    el.addEventListener('mouseleave', function() {
        el.style.backgroundImage = 'url(' + front + ')';
    });
});
</script>

