<!-- Newsletter Popup -->
<div id="newsletter-popup" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.8); z-index:10000; justify-content:center; align-items:center;">
    <div style="background:white; border-radius:16px; padding:36px; width:520px; max-width:95vw; max-height:90vh; overflow-y:auto; box-shadow:0 10px 40px rgba(0,0,0,0.3);">
        <div style="display:flex; align-items:center; margin-bottom:20px; border-bottom:2px solid #e0e5ea; padding-bottom:16px;">
            <div style="background:#1d3961; border-radius:50%; width:44px; height:44px; display:flex; align-items:center; justify-content:center; margin-right:14px; flex-shrink:0; font-size:20px;">✉️</div>
            <div>
                <h2 style="margin:0; color:#1d3961; font-family:'Noto Serif Display'; font-weight:800; font-size:22px;">Join the Cabbage Coins List</h2>
                <p style="margin:0; color:#6289c1; font-family:'Roboto'; font-size:13px;">First notice on new inventory + wish list matching</p>
            </div>
        </div>
        <form action="https://formspree.io/f/xjgprnzv" method="POST">
            <input type="hidden" name="_subject" value="New Newsletter & Wishlist Signup - Cabbage Coins">
            <input type="hidden" name="form_type" value="Newsletter & Wishlist Signup">
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:12px;">
                <div>
                    <label class="sell-label">Your Name</label>
                    <input class="form-control sell-input" type="text" name="name" placeholder="John Smith" required>
                </div>
                <div>
                    <label class="sell-label">Your Email</label>
                    <input class="form-control sell-input" type="email" name="email" placeholder="john@email.com" required>
                </div>
            </div>
            <div style="margin-bottom:12px;">
                <label class="sell-label">What coins are you looking for?</label>
                <textarea class="form-control sell-input" name="wishlist" rows="4" placeholder="e.g. Early American copper MS63+, Morgan Dollars CAC, gold type coins under $5000..."></textarea>
            </div>
            <div style="margin-bottom:12px;">
                <label class="sell-label">How did you hear about us? (optional)</label>
                <input class="form-control sell-input" type="text" name="how_did_you_hear" placeholder="Instagram, podcast, friend, coin show...">
            </div>
            <div style="margin-bottom:16px;">
                <input type="checkbox" id="newsletter-privacy" name="privacypolicy" required>
                <label for="newsletter-privacy" style="margin-left:8px; font-family:'Roboto'; font-size:14px; color:#444;">
                    I agree to the <a href="/privacypolicy/" target="_blank" style="color:#6289c1;">privacy policy</a>.
                </label>
            </div>
            <div style="display:flex; gap:12px;">
                <button type="submit" class="btn btn-primary" style="font-size:16px; padding:10px 28px; flex:1;">Sign Me Up</button>
                <button type="button" onclick="document.getElementById('newsletter-popup').style.display='none'" style="font-size:16px; padding:10px 20px; background:none; border:1px solid #ccc; border-radius:6px; cursor:pointer; color:#666;">Cancel</button>
            </div>
        </form>
    </div>
</div>
<script>
document.querySelectorAll('.image-dummy[data-img-back]').forEach(function(el) {
    const front = el.dataset.imgFront;
    const back = el.dataset.imgBack;
    if (!back || back === 'undefined?h=900') return;
    el.addEventListener('mouseenter', function() {
        el.style.backgroundImage = 'url(' + back + ')';
    });
    el.addEventListener('mouseleave', function() {
        el.style.backgroundImage = 'url(' + front + ')';
    });
});
</script>

