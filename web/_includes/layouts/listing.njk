---
layout: layouts/base.njk
templateClass: tmpl-listing
parent: Inventory
---
   <div class="container site-section main-section" id="listing">
        <div class="cc-listing">
            <div class="cc-listing-grid">
                <!-- IMAGES -->
                <div class="cc-img-col">
                    <a href="{{ listing.imageUrl }}" target="_blank" data-lightbox="coins">
                        <img class="cc-coin" src="{{ listing.imageUrl }}?h=1020" alt="{{ listing.name }} obverse">
                    </a>
{% if listing.galleryImageUrl[0] %}
                    <a href="{{ listing.galleryImageUrl[0] }}" target="_blank" data-lightbox="coins">
                        <img class="cc-coin" src="{{ listing.galleryImageUrl[0] }}?h=1020" alt="{{ listing.name }} reverse">
                    </a>
{% endif %}
{% if listing.image.caption %}
                    <div class="cc-coin-caption">"{{ listing.image.caption }}"</div>
{% endif %}
                    <div class="cc-thumb-row">
                    {% for image in listing.galleryImageUrl %}
                        {% if not loop.first %}
                        <a href="{{ image }}" target="_blank" data-lightbox="coins">
                            <div class="cc-thumb" style="background-image: url({{ image }}?h=200)"></div>
                        </a>
                        {% endif %}
                    {% endfor %}
                    </div>
                </div>

                <!-- INFO -->
                <div class="cc-info-col">
                    <h1 class="cc-title">{{ listing.name }}</h1>
                    <div class="cc-price-row">
                        {% if listing.sold %}
                        <span class="cc-price"><strike>${{ listing.price }}</strike></span>
                        <span class="cc-status cc-status-sold">Sold</span>
                        {% else %}
                        <span class="cc-price">${{ listing.price }}</span>
                        <span class="cc-status">Available</span>
                        {% endif %}
                    </div>

                    <div class="cc-spec"><span class="cc-spec-label">Issue</span><span class="cc-spec-value">{{ listing.dateshown }}</span></div>
                    <div class="cc-spec"><span class="cc-spec-label">Grading Company</span><span class="cc-spec-value">{{ listing.gradingCompany }}</span></div>
                    <div class="cc-spec"><span class="cc-spec-label">Certification #</span><span class="cc-spec-value">{{ listing.gradenumber }}</span></div>
                    <div class="cc-spec"><span class="cc-spec-label">Grade</span><span class="cc-spec-value">{{ listing.grade }}</span></div>
                    <div class="cc-spec"><span class="cc-spec-label">PCGS Catalog #</span><span class="cc-spec-value">{{ listing.pcgsCatalogNumber }}</span></div>

                    {% if listing.cac %}
                    <div class="cc-badge-row">
                        <img class="cc-cac-badge" src="/assets/img/caccoin.png" alt="CAC verified">
                        <span class="cc-cac-text">CAC verified &mdash; green sticker</span>
                    </div>
                    {% endif %}

                    {% if not listing.sold %}
                    <button class="cc-inquire-btn" id="lightbox-form-button" type="button"><i class="fa fa-envelope"></i> Inquire</button>
                    {% endif %}

                    {% if listing.description %}
                    <div class="cc-tony-says">
                        <div class="cc-tony-head">
                            <img class="cc-tony-emblem" src="/assets/img/CabbageCoins_Emblem_Small.png" alt="">
                            <h3 class="cc-tony-title">Tony Says</h3>
                            <span class="cc-tony-rule"></span>
                        </div>
                        <p class="cc-tony-body">{{ listing.description }}</p>
                    </div>
                    {% endif %}
                </div>
            </div>
        </div>
<div id="lightbox-form">
    <div class="inquiry-form">
        <div style="display:flex; align-items:center; margin-bottom:20px; border-bottom:2px solid #e0e5ea; padding-bottom:16px;">
            <div style="background:#1d3961; border-radius:50%; width:44px; height:44px; display:flex; align-items:center; justify-content:center; margin-right:14px; flex-shrink:0;">
                <svg xmlns='http://www.w3.org/2000/svg' width='22' height='22' fill='white' viewBox='0 0 16 16'><path d='M2 2a2 2 0 0 0-2 2v8.01A2 2 0 0 0 2 14h5.5a.5.5 0 0 0 0-1H2a1 1 0 0 1-.966-.741l5.64-3.471L8 9.583l7-4.2V8.5a.5.5 0 0 0 1 0V4a2 2 0 0 0-2-2H2zm3.708 6.208L1 11.105V5.383l4.708 2.825zM1 4.217V4a1 1 0 0 1 1-1h12a1 1 0 0 1 1 1v.217l-7 4.2-7-4.2z'/></svg>
            </div>
            <div>
                <h2 style="margin:0; color:#1d3961; font-family:'Noto Serif Display'; font-weight:800; font-size:24px;">Inquire About This Coin</h2>
                <p style="margin:0; color:#6289c1; font-family:'Roboto'; font-size:14px;">{{ listing.name }}</p>
            </div>
        </div>

            <form action="https://formspree.io/f/xzdkqbva" method="POST">
                <input type="hidden" name="_subject" value="Purchase Inquiry - {{ listing.name }}">
                <input type="hidden" name="form_type" value="Coin Purchase Inquiry">

            <div style="display:grid; grid-template-columns:1fr 1fr; gap:14px; margin-bottom:14px;">
                <div>
                    <label class="sell-label">Your Name</label>
                    <input class="form-control sell-input" type="text" name="name" placeholder="John Smith" required>
                </div>
                <div>
                    <label class="sell-label">Your Email</label>
                    <input class="form-control sell-input" type="email" name="email" placeholder="john@email.com" required>
                </div>
            </div>

            <div style="margin-bottom:14px;">
                <label class="sell-label">Phone Number (optional)</label>
                <input class="form-control sell-input" type="tel" name="phone" placeholder="(717) 555-1234">
            </div>

            <div style="margin-bottom:14px;">
                <label class="sell-label">Message</label>
                <textarea class="form-control sell-input" name="message" rows="6">Hello Tony,
I am interested in purchasing the {{ listing.name }} listed at ${{ listing.price }}.
My preferred payment method is: (Zelle, Venmo, Paypal FF, Check)
Please contact me at your earliest convenience to discuss this purchase.
[please add your phone number here]
Thank you!</textarea>
            </div>

            <div style="margin-bottom:16px;">
                <input type="checkbox" id="privacypolicy" name="privacypolicy" required>
                <label for="privacypolicy" style="margin-left:8px; font-family:'Roboto'; font-size:14px; color:#444;">
                    I agree to the <a href="/privacypolicy/" target="_blank" style="color:#6289c1;">privacy policy</a>.
                </label>
            </div>

            <div style="display:flex; gap:12px;">
                <button class="btn btn-primary" type="submit" style="font-size:16px; padding:10px 28px; flex:1;">Send Inquiry</button>
                <button type="button" onclick="document.getElementById('lightbox-form').classList.remove('active')" style="font-size:16px; padding:10px 20px; background:none; border:1px solid #ccc; border-radius:6px; cursor:pointer; color:#666;">Cancel</button>
            </div>
        </form>
    </div>
</div>
<script>
            (function() {
                var form = document.querySelector('#lightbox-form form');
                if (form) {
                    form.addEventListener('submit', function() {
                        var email = form.querySelector('input[name="email"]').value;
                        var input = document.createElement('input');
                        input.type = 'hidden';
                        input.name = '_replyto';
                        input.value = email;
                        form.appendChild(input);
                    });
                }
            })();
            </script>